# Refinery demo orchestrator — configuration (copy to .env; .env is gitignored).
# Public repo: NEVER put a real secret here. The fleet JWT secret comes from the
# environment / Secret Manager at runtime, never from a committed file.

# --- Orchestrator ---
REFINERY_API_PORT=7090
REFINERY_TOPOLOGY=refinery/topology/baytown.yaml
REFINERY_TICK_SECONDS=1.0

# --- Real bard-infra Registry the orchestrator projects elements into ---
REFINERY_REGISTRY_URL=http://127.0.0.1:8081
REFINERY_HEARTBEAT_SECONDS=15
# Shared fleet JWT (bard-infra BARDPRO_JWT_SECRET; >=32 bytes). Demo only.
# Provide via env or Secret Manager — do NOT commit a real value.
REFINERY_JWT_SECRET=
REFINERY_JWT_ISSUER=bardllm-pro

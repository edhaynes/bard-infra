# Bard console configuration (Vite env vars; copy to .env.local — gitignored).
# All three are read at build/dev time by src/config.ts.

# Where your Registry's control-plane API lives (required unless demo mode).
# Example for the default local stack: the Registry listens on 8081.
VITE_API_BASE_URL=http://localhost:8081

# Token the console presents to read your device list (required unless demo
# mode). Dev posture: the Registry's bearer JWT. Never commit a real token.
VITE_API_TOKEN=

# Demo mode: show built-in sample devices instead of calling the API.
# Explicit opt-in only — the console never falls back to samples on its own.
VITE_USE_SAMPLE_DATA=false

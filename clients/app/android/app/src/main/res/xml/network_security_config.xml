<?xml version="1.0" encoding="utf-8"?>
<!--
  Bard LLM Android cleartext policy.

  Apps targeting API >= 28 (this app is targetSdk 36) have cleartext (plain HTTP)
  traffic BLOCKED by the platform default. Without this file the client cannot
  reach an all-HTTP local fleet at all — the request fails with
  "Cleartext HTTP traffic to <host> not permitted" before a socket is opened.

  Posture mirrors the server-side gating (bugs #53 / #60): plain HTTP is a
  deliberate LOCAL/DEV opt-in, never the production wire default. So:

    - base-config stays cleartextTrafficPermitted="false" -> any real
      router/registry URL is HTTPS-only, in every build type.
    - the domain-config below permits cleartext ONLY to the loopback hosts a
      developer points the app at when wiring it to a local fleet:
        127.0.0.1 / localhost : fleet on the same device, or reached via
                                `adb reverse tcp:8080 tcp:8080` (the default
                                BARD_ROUTER_URL then "just works")
        10.0.2.2              : the Android emulator's alias for the host loopback
        10.0.3.2              : the Genymotion emulator's host-loopback alias

  A physical phone hitting a fleet on the LAN by IP is a dev scenario: use
  `adb reverse` (then 127.0.0.1, already permitted) rather than widening this to
  the whole LAN, which would relax cleartext for arbitrary hosts.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
    </domain-config>
</network-security-config>

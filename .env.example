# Bard — copy to .env and fill in. The real .env is gitignored.
# Every var is prefixed BARDPRO_ and maps to a common.config.Config field.

# --- Auth (REQUIRED at runtime) ---
# HMAC secret for JWT signing/verification. REQUIRED. Never commit a real value.
BARDPRO_JWT_SECRET=
BARDPRO_JWT_ALGORITHM=HS256
BARDPRO_JWT_ISSUER=bardllm-pro

# --- Per-device identity (Sprint B2 / ADR-0010, pragmatic JWT-class) ---
# OPT-IN. When false (default) the fleet-wide BARDPRO_JWT_SECRET above signs and
# verifies every agent (v1.x behaviour, unchanged). When true the Registry issues
# per-device credentials through an enrollment lifecycle (join-token -> pending
# -> active -> revoked) and verifies them per device. NOT the v3 PQ/MLS fabric.
BARDPRO_DEVICE_IDENTITY_ENABLED=false
# Where the Registry persists device records (parallel to the agent state file).
BARDPRO_DEVICE_STORE_PATH=./device-state.json
# HMAC key that signs/verifies short-lived join tokens. REQUIRED (and >=32 bytes)
# when device identity is enabled. Distinct from BARDPRO_JWT_SECRET. Never commit.
BARDPRO_DEVICE_JOIN_SECRET=
# Join-token / per-device-token lifetimes, seconds.
BARDPRO_DEVICE_JOIN_TOKEN_TTL_S=900
BARDPRO_DEVICE_TOKEN_TTL_S=3600
# Agent side only: the per-device HMAC secret THIS agent received at approval.
# Used (with sub=agent_id) instead of BARDPRO_JWT_SECRET when device identity is on.
BARDPRO_DEVICE_SECRET=
# Append-only JSONL audit of console/management actions (Sprint B6 — who
# approved/revoked/renamed/grouped which device, when; Sprint B8 adds plugin
# enable/disable/config). Wired alongside device identity; its own file,
# parallel to the device/agent/channel state files.
BARDPRO_AUDIT_LOG_PATH=./audit-log.jsonl

# --- Plugin manage (Sprint B8 — console Plugins pane, feature #65) ---
# Wired alongside device identity. The catalog dir holds the *.manifest.json
# files (validated at startup against contracts/plugin-manifest.schema.json —
# a missing or invalid catalog fails fast). State (enable per device/workgroup,
# per-target config, reported health) persists in its own JSON file.
BARDPRO_PLUGIN_CATALOG_DIR=./examples/plugins
BARDPRO_PLUGIN_STATE_PATH=./plugin-state.json
# Freshness window for reported plugin health, seconds — a report older than
# this shows as "stale" (the agent-heartbeat rule applied to plugins).
BARDPRO_PLUGIN_HEALTH_TTL_S=45

# --- Channel invites (Sprint B3 — "send a link, click, you're in") ---
# Rides on device identity: only wired when BARDPRO_DEVICE_IDENTITY_ENABLED=true.
# HMAC key that signs/verifies single-use channel invite tokens. REQUIRED (and
# >=32 bytes) when device identity is enabled. Its OWN key, distinct from both
# BARDPRO_JWT_SECRET and BARDPRO_DEVICE_JOIN_SECRET. Never commit a real value.
BARDPRO_CHANNEL_INVITE_SECRET=
# Invite lifetime, seconds (default 7 days — long enough to text a crew).
BARDPRO_CHANNEL_INVITE_TTL_S=604800
# Public link/QR landing the invite token is embedded into (?invite=<token>).
# The client mobile app redeems it. REQUIRED when device identity is enabled.
BARDPRO_INVITE_BASE_URL=

# --- Router ---
BARDPRO_ROUTER_HOST=127.0.0.1
BARDPRO_ROUTER_PORT=8443

# --- Registry ---
BARDPRO_REGISTRY_HOST=127.0.0.1
BARDPRO_REGISTRY_PORT=8081
BARDPRO_REGISTRY_STATE_PATH=./registry-state.json
# Scheme the agent uses to self-register: https (default) or http.
# http is refused at startup unless BARDPRO_ALLOW_INSECURE_HTTP=true is set too.
BARDPRO_REGISTRY_SCHEME=https
# Explicit opt-in for plain-HTTP registration (logs a WARNING). Only acceptable
# over an already-encrypted hop (e.g. Tailscale/WireGuard, as in the demo).
BARDPRO_ALLOW_INSECURE_HTTP=false

# --- Agent ---
BARDPRO_AGENT_HOST=127.0.0.1
BARDPRO_AGENT_PORT=8444
BARDPRO_MODEL_DIR=./models
BARDPRO_POWER_PROFILE_PATH=./power-profile.yaml

# --- Inference engine (Sprint 1) ---
# echo = demo/fakes path; llamacpp = talk to a co-located llama.cpp
# OpenAI-compatible server (/v1/chat/completions).
BARDPRO_INFERENCE_BACKEND=echo
BARDPRO_LLAMA_BASE_URL=http://127.0.0.1:8080/v1
BARDPRO_LLAMA_MODEL=local-gguf
# llama.cpp ignores the key, but a value is allowed for OpenAI-compatible proxies.
BARDPRO_LLAMA_API_KEY=
BARDPRO_INFERENCE_MAX_TOKENS=512
BARDPRO_INFERENCE_TEMPERATURE=0.7
# GGUF model fetched by scripts/fetch_model.sh into ${BARDPRO_MODEL_DIR}/model.gguf.
# Default is a small (~350 MB) Qwen2.5-0.5B-Instruct Q4_K_M (Apache-2.0), good for
# laptops/CI without a GPU; override for production-sized models.
BARDPRO_MODEL_URL=https://huggingface.co/Qwen/Qwen2.5-0.5B-Instruct-GGUF/resolve/main/qwen2.5-0.5b-instruct-q4_k_m.gguf
# Optional: expected SHA-256 of the GGUF; verified by fetch_model when set.
BARDPRO_MODEL_SHA256=
# Optional: thread count passed to llama-server (defaults to llama.cpp's choice).
BARDPRO_LLAMA_THREADS=

# --- TLS (paths only; key material is never stored in config) ---
BARDPRO_TLS_CERT_PATH=
BARDPRO_TLS_KEY_PATH=

# --- Ops ---
BARDPRO_LOG_LEVEL=INFO
BARDPRO_REQUEST_TIMEOUT_S=30
# on by default: peers must be resolvable names; set false to allow raw-IP peers
BARDPRO_ENFORCE_PEER_NAME_RESOLUTION=true
